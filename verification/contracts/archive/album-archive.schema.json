{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/infopek/categorizer/verification/contracts/archive/album-archive.schema.json",
  "title": "Categorizer album archive manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format",
    "archive_schema_version",
    "archive_id",
    "created_at_epoch_ms",
    "exporting_app",
    "entry_count",
    "image_count",
    "entries",
    "image_files"
  ],
  "properties": {
    "format": {"const": "categorizer-album-archive"},
    "archive_schema_version": {"const": "1.0.0"},
    "archive_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"
    },
    "created_at_epoch_ms": {"type": "integer", "minimum": 0},
    "exporting_app": {
      "type": "object",
      "additionalProperties": false,
      "required": ["application_id", "version_name", "version_code"],
      "properties": {
        "application_id": {"type": "string", "minLength": 1},
        "version_name": {"type": "string", "minLength": 1},
        "version_code": {"type": "integer", "minimum": 1}
      }
    },
    "entry_count": {"type": "integer", "minimum": 0, "maximum": 10000},
    "image_count": {"type": "integer", "minimum": 0, "maximum": 10000},
    "entries": {
      "type": "array",
      "maxItems": 10000,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "entry_id",
          "entry_schema_version",
          "image_id",
          "confirmed_identity",
          "album_date",
          "is_favorite",
          "notes",
          "created_at_epoch_ms",
          "updated_at_epoch_ms"
        ],
        "properties": {
          "entry_id": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"
          },
          "entry_schema_version": {"const": 1},
          "image_id": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"
          },
          "confirmed_identity": {
            "type": "object",
            "additionalProperties": false,
            "required": ["class_id", "make", "model", "display_name", "source"],
            "properties": {
              "class_id": {
                "type": "string",
                "pattern": "^[a-z0-9][a-z0-9-]*$"
              },
              "make": {"type": "string", "minLength": 1},
              "model": {"type": "string", "minLength": 1},
              "generation_label": {"type": "string", "minLength": 1},
              "approximate_year_range": {"type": "string", "minLength": 1},
              "display_name": {"type": "string", "minLength": 1},
              "source": {"enum": ["MODEL_CATALOG", "USER_CONFIRMED"]}
            }
          },
          "album_date": {
            "type": "string",
            "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
          },
          "is_favorite": {"type": "boolean"},
          "notes": {"type": "string", "maxLength": 100000},
          "created_at_epoch_ms": {"type": "integer", "minimum": 0},
          "updated_at_epoch_ms": {"type": "integer", "minimum": 0}
        }
      }
    },
    "image_files": {
      "type": "array",
      "maxItems": 10000,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "image_id",
          "relative_path",
          "media_type",
          "size_bytes",
          "sha256"
        ],
        "properties": {
          "image_id": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"
          },
          "relative_path": {
            "type": "string",
            "maxLength": 240,
            "pattern": "^images/[A-Za-z0-9][A-Za-z0-9._-]{0,127}\\.(jpg|jpeg|png|webp)$"
          },
          "media_type": {
            "enum": ["image/jpeg", "image/png", "image/webp"]
          },
          "size_bytes": {
            "type": "integer",
            "minimum": 1,
            "maximum": 52428800
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        }
      }
    }
  }
}
